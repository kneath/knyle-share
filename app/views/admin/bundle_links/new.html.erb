<% content_for :title, "Generate Link · Knyle Share" %>

<div class="page">
  <%= render "admin/shared/header" %>

  <main>
    <div class="container">
      <div class="breadcrumb">
        <a href="<%= admin_bundles_path %>">Bundles</a> / <a href="<%= admin_bundle_path(@bundle[:slug]) %>"><%= @bundle[:slug] %></a> / Generate link
      </div>

      <div class="page-title">
        <h1>Generate expiring link</h1>
      </div>

      <p class="text-muted mb-2">
        Create a link that grants access to <strong style="color: var(--color-text);"><%= @bundle[:slug] %></strong> without requiring a password. The link will expire after the chosen duration.
      </p>

      <div class="detail-section">
        <h2>Choose expiration</h2>
        <div class="pill-group mt-1">
          <button class="pill" type="button">1 day</button>
          <button class="pill is-selected" type="button">1 week</button>
          <button class="pill" type="button">1 month</button>
        </div>

        <div class="mt-3">
          <button class="btn btn-primary" type="button">Generate link</button>
        </div>
      </div>

      <div class="detail-section">
        <h2>Your expiring link</h2>
        <p class="text-muted mb-1" style="font-size: 0.87rem;">
          This placeholder link expires in 1 week. Milestone 3 will replace this page with a real signed-link form backed by the app.
        </p>

        <div class="copy-box">
          <code><%= "#{@bundle[:bundle_url]}?access=placeholder-signed-token" %></code>
          <button class="btn btn-secondary" type="button">Copy</button>
        </div>
      </div>
    </div>
  </main>
</div>
