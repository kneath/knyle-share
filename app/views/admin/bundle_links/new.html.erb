<% content_for :title, "Generate Link · Knyle Share" %>

<div class="page">
  <%= render "admin/shared/header" %>

  <main>
    <div class="container">
      <div class="breadcrumb">
        <a href="<%= admin_bundles_path %>">Bundles</a> /
        <a href="<%= admin_bundle_path(@bundle) %>"><%= @bundle.slug %></a> /
        Generate link
      </div>

      <div class="page-title">
        <h1>Generate expiring link</h1>
      </div>

      <p class="text-muted mb-2">
        Create a link that grants access to <strong style="color: var(--color-text);"><%= @bundle.slug %></strong> without requiring a password. The link will expire after the chosen duration.
      </p>

      <div class="detail-section">
        <h2>Choose expiration</h2>
        <p class="text-muted mt-1">Each button generates a new signed URL with the selected expiration.</p>

        <%= form_with url: admin_bundle_link_path(@bundle), method: :post, class: "stack-form mt-2" do %>
          <div class="pill-group">
            <% @expiration_presets.each do |key, preset| %>
              <button class="pill <%= "is-selected" if @selected_preset == key %>" type="submit" name="expires_in" value="<%= key %>">
                <%= preset.fetch(:label) %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="detail-section">
        <h2>Your expiring link</h2>
        <% if @generated_link.present? %>
          <p class="text-muted mb-1">
            This link expires <%= time_tag(@expires_at, @expires_at.strftime("%b %-d, %Y at %-I:%M %p")) %>.
          </p>

          <div class="copy-box">
            <code><%= @generated_link %></code>
          </div>
        <% else %>
          <p class="text-muted mb-1">
            No link generated yet. Choose one of the expiration presets above to mint a signed link.
          </p>
        <% end %>
      </div>
    </div>
  </main>
</div>
