<header class="header-bar">
  <a href="<%= admin_bundles_path %>" class="brand">Knyle Share</a>
  <nav>
    <a href="<%= admin_bundles_path %>">Bundles</a>
    <span><%= installation.admin_label %></span>
    <form action="<%= admin_logout_path %>" method="post" class="inline-form">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <button class="btn btn-ghost btn-small" type="submit">Sign out</button>
    </form>
  </nav>
</header>
