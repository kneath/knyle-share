<% content_for :title, "Bundles · Knyle Share" %>

<div class="page">
  <%= render "admin/shared/header" %>

  <main>
    <div class="container">
      <div class="page-title">
        <h1>Bundles <span class="count"><%= @bundles.length %></span></h1>
      </div>

      <div class="card">
        <ul class="bundle-list">
          <% @bundles.each do |bundle| %>
            <li>
              <a href="<%= admin_bundle_path(bundle[:slug]) %>" class="bundle-item <%= "is-disabled" if bundle[:status_label] == "Disabled" %>">
                <div>
                  <div class="bundle-name"><%= bundle[:slug] %></div>
                  <div class="bundle-meta">
                    <span class="badge"><%= bundle[:presentation_label] %></span>
                    <span class="badge <%= bundle[:access_class] %>"><%= bundle[:access_label] %></span>
                    <span class="badge <%= bundle[:status_class] %>"><%= bundle[:status_label] %></span>
                  </div>
                </div>
                <div class="bundle-stats">
                  <div class="views"><%= bundle[:views] %></div>
                  <div class="last-viewed"><%= bundle[:last_viewed] %></div>
                </div>
              </a>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </main>
</div>
