<% content_for :title, "#{@bundle.title} · Knyle Share" %>

<div class="page">
  <main>
    <div class="container">
      <div class="page-title">
        <h1><%= @bundle.title %></h1>
      </div>

      <div class="detail-section">
        <div class="text-muted mb-2"><%= @bundle.slug %></div>
        <article>
          <%= @rendered_markdown.html_safe %>
        </article>
      </div>

      <div class="home-actions">
        <a class="btn btn-secondary" href="<%= public_raw_bundle_path(slug: @bundle.slug, access: params[:access]) %>">View raw markdown</a>
        <a class="btn btn-primary" href="<%= public_download_bundle_path(slug: @bundle.slug, access: params[:access]) %>">Download file</a>
      </div>
    </div>
  </main>
</div>
