<% content_for :title, "#{@bundle.title} · Knyle Share" %>

<div class="video-display">
  <div class="video-display-viewport">
    <video controls preload="metadata" src="<%= @video_url %>" type="<%= @entry_asset.content_type %>">
      Your browser does not support video playback.
    </video>
  </div>

  <footer class="video-display-actions">
    <div>
      <h1><%= @bundle.title %></h1>
      <p class="text-muted">
        <%= public_bundle_file_name(@entry_asset) %> · <%= public_bundle_size_label(@entry_asset.byte_size) %>
      </p>
    </div>

    <a class="btn btn-primary" href="<%= public_bundle_download_url_for(@bundle, access_token: params[:access]) %>">
      Download file
    </a>
  </footer>
</div>
