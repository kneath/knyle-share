<% content_for :title, "Is There a There There? · Knyle Share" %>

<div class="threshold-page" data-there-state="threshold">
  <main class="threshold-shell">
    <section class="threshold-intro">
      <p class="threshold-epigraph">You have arrived at the edge of something</p>
      <h1 class="threshold-question">
        <span class="threshold-q-line">Is there</span>
        <span class="threshold-q-line threshold-q-indent">a <em>there</em></span>
        <span class="threshold-q-line">there?</span>
      </h1>
    </section>

    <section class="threshold-body">
      <p class="threshold-copy">
        If you weren't given a link, you shouldn't be here. This is not a directory, only the quiet edge where shared things pass through.
      </p>

      <nav class="threshold-choices" aria-label="Choose a way of approaching the threshold">
        <button class="threshold-choice" type="button" data-there-option="knock" aria-pressed="false">Knock</button>
        <button class="threshold-choice" type="button" data-there-option="listen" aria-pressed="false">Listen</button>
        <button class="threshold-choice" type="button" data-there-option="lose-map" aria-pressed="false">Lose the map</button>
      </nav>
    </section>

    <aside class="threshold-response" aria-live="polite">
      <p class="threshold-response-label" data-there-mark>The threshold answers</p>
      <p class="threshold-answer" data-there-answer>
        Every destination begins as a rumor. Choose a way of arriving and watch the room refuse to become a room.
      </p>
    </aside>

    <footer class="threshold-coda">
      <p>Bundles are meant to be reached by invitation. They appear plainly enough once someone hands you the right path.</p>
    </footer>
  </main>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const page = document.querySelector("[data-there-state]");
    const answer = document.querySelector("[data-there-answer]");
    const mark = document.querySelector("[data-there-mark]");
    const choices = document.querySelectorAll("[data-there-option]");

    if (!page || !answer || !mark || choices.length === 0) return;

    const responses = {
      knock: {
        mark: "The threshold says",
        answer: "Every link points somewhere, but the address is not the arrival. Shared things are invitations, not exhibits."
      },
      listen: {
        mark: "The threshold whispers",
        answer: "There is no directory hiding behind the curtain. This host is mostly an opening, patiently waiting for the names that were meant to pass through it."
      },
      "lose-map": {
        mark: "The threshold laughs",
        answer: "The search for the hidden room is the room. Stop asking the doorway to become a catalog and it will finally act like a doorway."
      }
    };

    function animateText(el, text) {
      el.style.animation = "none";
      el.offsetHeight; // force reflow
      el.textContent = text;
      el.style.animation = "threshold-materialize 0.8s ease-out forwards";
    }

    choices.forEach((choice) => {
      choice.addEventListener("click", () => {
        const state = choice.dataset.thereOption;
        const response = responses[state];
        if (!response) return;

        page.dataset.thereState = state;
        animateText(mark, response.mark);
        animateText(answer, response.answer);

        choices.forEach((button) => {
          button.setAttribute("aria-pressed", String(button === choice));
        });
      });
    });
  });
</script>
